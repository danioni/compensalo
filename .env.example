# Database — misma URL que Balancealo (Compensalo usa schema separado "compensalo")
DATABASE_URL="postgresql://user:password@localhost:5432/balancealo?schema=compensalo"

# Secreto compartido para verificar firma HMAC de webhooks de Habilitalo
HABILITALO_WEBHOOK_SECRET="your-webhook-secret-here"

# URL pública de esta app (para registro de webhook en Habilitalo)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# URL pública de Compensalo (usada por el script de registro de webhook)
COMPENSALO_WEBHOOK_URL="http://localhost:3000"

# URL base de Habilitalo/Balancealo (para script de auto-registro)
HABILITALO_BASE_URL="http://localhost:3001"
